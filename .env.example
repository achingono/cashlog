# Database
POSTGRES_DB=finance
POSTGRES_USER=finance
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://finance:changeme_in_production@postgres:5432/finance

# SimpleFin Bridge
# Run: simplefin-cli setup <base64-token> to get your access URL
SIMPLEFIN_ACCESS_URL=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
# Use your Azure deployment name exactly as configured in Azure AI Studio (not just the model family name)
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# App Settings
NODE_ENV=production
API_PORT=3000
SPA_PORT=80
