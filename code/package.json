{
  "name": "finance-dashboard",
  "private": true,
  "workspaces": [
    "api",
    "spa",
    "worker"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:spa": "npm run dev --workspace=spa",
    "dev:worker": "npm run dev --workspace=worker",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspace=api && npm run test --workspace=spa && npm run test --workspace=worker",
    "test:api": "npm run test --workspace=api",
    "test:spa": "npm run test --workspace=spa",
    "test:worker": "npm run test --workspace=worker",
    "test:coverage": "npm run test:coverage --workspace=api && npm run test:coverage --workspace=spa && npm run test:coverage --workspace=worker",
    "test:e2e": "npm run test:e2e --workspace=spa",
    "test:e2e:headed": "npm run test:e2e:headed --workspace=spa",
    "db:migrate": "npx prisma migrate dev --schema=prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "db:seed": "npx ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "vitest": "^1.6.0"
  }
}
